{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\MSSQLSERVER01;Database=TradingBotDb;Trusted_Connection=True;TrustServerCertificate=TRUE;"
  },

  "Binance": {
    "BaseUrl": "https://demo-api.binance.com"
  },

  "Auth": {
    "DefaultAdminUsername": "admin"
  },

  "AI": {
    "GeminiModel": "gemini-2.0-flash",
    "GroqModel": "llama-3.1-70b-versatile",
    "OpenRouterModel": "meta-llama/llama-3.1-8b-instruct:free",
    "CohereModel": "command-r",

    "RateLimitBackoffSeconds": 90,
    "MinConfidenceToTrade": 70,

    "ProviderPriority": [ "Gemini", "Groq", "OpenRouter", "Cohere" ]
  },

  "Strategy": {
    "StrategyMode": "Strict",
    "RelaxedRsiMax": 55.0,
    "MomentumRsiMin": 55.0,
    "MomentumRsiMax": 70.0,
    "RequireVolumeSpikeForMomentum": true,
    "RsiStrongOversold": 30.0,
    "RsiOversold": 45.0,
    "RsiOverbought": 70.0,
    "SupportProximityPct": 0.02,
    "SlAtrMultiplier": 1.5,
    "TpAtrMultiplier": 3.0,
    "MinConfidence": 70,
    "PtsRsiStrongOversold": 30,
    "PtsRsiMildOversold": 15,
    "PtsEmaUptrend": 25,
    "PtsMacdBullish": 20,
    "PtsVolumeSpike": 15,
    "PtsNearSupport": 10
  },

  "Trading": {
    "SignalScanIntervalMinutes": 5,
    "SignalScanTimeframe": "1h",
    "ScanCandleCount": 100,
    "UseProfitTarget": false,
    "ProfitTargetMinUsd": 20.0,
    "ProfitTargetMaxUsd": 50.0,
    "MinRewardRiskMultiple": 1.5,
    "MaxRewardRiskMultiple": 4.0,
    "AdjustStopsToFillPrice": true,
    "MaxTradesPerMinute": 3,
    "MinSecondsBetweenTrades": 20
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "TradingBot.Infrastructure.AI": "Information"
    }
  },

  "AllowedHosts": "*"
}
