        <button class="filter-chip log-filter-btn" data-level="WARN" onclick="Logs.setFilter('WARN')" style="color:var(--yellow)">WARN</button>
        <button class="filter-chip log-filter-btn" data-level="ERROR" onclick="Logs.setFilter('ERROR')" style="color:var(--red)">ERR</button>
