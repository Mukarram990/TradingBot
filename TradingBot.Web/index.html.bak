        <button class="btn btn-ghost btn-sm" id="logs-pause-btn" onclick="Logs.setPaused(true)">⏸ Pause</button>
        <button class="btn btn-ghost btn-sm" onclick="Logs.clear()">🗑 Clear</button>
        <button class="btn btn-ghost btn-sm" onclick="
          const p=document.getElementById('logs-panel');
          const app=document.getElementById('app');
          const cur=parseInt(getComputedStyle(app).getPropertyValue('--bottom-panel-h'));
          app.style.setProperty('--bottom-panel-h', cur>50?'32px':'200px')
        ">▼</button>
